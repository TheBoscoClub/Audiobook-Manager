[Unit]
Description=Audiobook translation pipeline (STT + DeepL + TTS)
Documentation=https://github.com/TheBoscoClub/Audiobook-Manager
After=network-online.target audiobook-api.service
Wants=network-online.target
PartOf=audiobook.target

[Service]
Type=simple
User=audiobooks
Group=audiobooks

# The daemon manages SSH tunnels and batch-translate workers.
# It exits cleanly (0) when the queue is empty, or on SIGTERM.
ExecStart=/opt/audiobooks/scripts/translation-daemon.sh

# Create log directory before starting
ExecStartPre=/bin/mkdir -p /var/log/audiobooks/translate

# Self-heal ownership drift: worker logs must be writable by the audiobooks
# service account. Interactive runs or manual debugging can leave files owned
# by another user, which silently breaks worker log writes. Runs as root via
# the `+` prefix, independent of User= below.
ExecStartPre=+/bin/chown -R audiobooks:audiobooks /var/log/audiobooks/translate
ExecStartPre=+/bin/chmod 0775 /var/log/audiobooks/translate

# On clean exit (queue empty): don't restart — the job is done.
# On failure: restart after 60s to retry dead tunnels/workers.
Restart=on-failure
RestartSec=60

# Allow generous startup time for SSH tunnels + model loading
TimeoutStartSec=300
TimeoutStopSec=60

# Send SIGTERM for graceful shutdown (resets stuck processing->pending)
KillSignal=SIGTERM
KillMode=mixed

# Resource limits
LimitNOFILE=4096

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=audiobook-translate

# Security hardening
NoNewPrivileges=yes
ProtectSystem=full
ProtectHome=read-only
PrivateTmp=yes

[Install]
WantedBy=audiobook.target
