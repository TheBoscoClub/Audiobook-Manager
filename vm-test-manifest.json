{
  "project": "Audiobook-Manager",
  "description": "Audiobooks Library — Flask API, systemd services, system-wide installation",

  "vm_testing": {
    "enabled": true,
    "required_for": [
      "System-wide installation (install-system.sh, install-services.sh)",
      "Systemd service management (audiobook.target, 5 services + timers)",
      "SSL certificate generation",
      "Environment profile installation (/etc/profile.d/)",
      "API integration tests",
      "UI/Playwright E2E tests",
      "WebAuthn/FIDO2 authentication flows"
    ],
    "reason": "Installs to /etc/systemd/system/, /usr/local/bin/, /usr/local/lib/, /opt/audiobooks/, /etc/profile.d/. Must not contaminate host.",

    "default_vm": "test-audiobook-cachyos",

    "dangerous_operations": [
      "systemd_service_install",
      "system_directory_creation",
      "ssl_certificate_generation",
      "environment_profile_install",
      "user_group_creation",
      "venv_system_install"
    ],

    "pristine_snapshot": "pristine",
    "post_test_restore": true,

    "test_environments": [
      {
        "name": "test-audiobook-cachyos",
        "type": "existing",
        "vm_name": "test-audiobook-cachyos",
        "snapshot": "pristine",
        "description": "Dedicated CachyOS VM for audiobook integration/API/UI testing. Restore to pristine snapshot after every test run.",
        "requirements": {
          "python": "3.14",
          "ffmpeg": true,
          "ffprobe": true,
          "systemd": true
        },
        "static_ip": "192.168.122.104",
        "ports": {
          "api": 5001,
          "web": 8443,
          "spice": 5900
        }
      }
    ],

    "test_categories": {
      "unit_tests": {
        "vm_required": false,
        "description": "Metadata, config, utility functions — safe locally",
        "run_command": "cd library && pytest tests/test_metadata_utils.py tests/test_config.py tests/test_common.py tests/test_editions.py -v"
      },
      "api_integration_tests": {
        "vm_required": true,
        "description": "API endpoint tests against running services — MUST use VM",
        "run_command": "cd library && pytest tests/ --vm -v",
        "markers": ["integration"]
      },
      "ui_tests": {
        "vm_required": true,
        "description": "Playwright browser tests for player navigation — MUST use VM",
        "run_command": "cd library && pytest tests/test_player_navigation_persistence.py --vm -v",
        "markers": ["integration"]
      },
      "auth_tests": {
        "vm_required": true,
        "description": "WebAuthn/FIDO2 auth flow tests — MUST use VM",
        "run_command": "cd library && pytest tests/test_auth_integration.py tests/test_auth_lifecycle_integration.py --vm -v",
        "markers": ["integration"]
      },
      "hardware_tests": {
        "vm_required": true,
        "description": "YubiKey/physical security key tests — needs --hardware flag",
        "run_command": "cd library && pytest tests/ --vm --hardware -v",
        "markers": ["hardware"]
      }
    },

    "install": {
      "script": "install.sh",
      "command": "./install.sh --system",
      "required_on_pristine": true,
      "creates": ["audiobooks user/group", "/opt/audiobooks/", "/etc/audiobooks/", "/var/lib/audiobooks/", "venv", "SSL certs", "systemd services"],
      "detects_pristine_by": "getent passwd audiobooks"
    },

    "deploy": {
      "script": "upgrade.sh",
      "command": "./upgrade.sh --from-project . --remote 192.168.122.104 --yes",
      "requires_install_first": true,
      "verify": [
        "ssh -i ~/.ssh/id_ed25519 claude@192.168.122.104 'cat /opt/audiobooks/VERSION'",
        "curl -s http://192.168.122.104:5001/api/system/version"
      ]
    }
  },

  "local_testing": {
    "safe_commands": [
      "cd library && pytest tests/test_metadata_utils.py tests/test_config.py tests/test_common.py -v",
      "ruff check library/",
      "mypy library/ --ignore-missing-imports",
      "bandit -r library/ -x library/tests"
    ],
    "unsafe_commands": [
      "pytest tests/ --vm",
      "install-system.sh",
      "install-services.sh",
      "upgrade.sh --remote"
    ]
  },

  "ssh_config": {
    "user": "claude",
    "key": "~/.ssh/id_ed25519",
    "password": "REDACTED_VM_PASSWORD"
  },

  "qa_vm": {
    "enabled": true,
    "vm_name": "qa-audiobook-cachyos",
    "static_ip": "192.168.122.63",
    "snapshot": "return-to-base-2026-02-23",
    "ports": {
      "native_api": 5001,
      "native_web": 8090,
      "docker_web_https": 8443,
      "docker_web_http": 8080
    },
    "docker": {
      "container_name": "audiobooks-docker",
      "image_prefix": "audiobook-manager",
      "daemon_preset": "disabled",
      "db_path": "/var/lib/audiobooks/docker-data/audiobooks.db",
      "library_mount": "/srv/audiobooks/Library:/audiobooks:ro",
      "supplements_mount": "/srv/audiobooks/Supplements:/supplements:ro",
      "data_volume": "/var/lib/audiobooks/docker-data:/app/data"
    },
    "native": {
      "app_path": "/opt/audiobooks",
      "db_path": "/var/lib/audiobooks/db/audiobooks.db",
      "version_file": "/opt/audiobooks/VERSION",
      "service_target": "audiobook.target"
    },
    "production_db": {
      "source_path": "/var/lib/audiobooks/db/audiobooks.db",
      "schema_version_query": "SELECT MAX(version) FROM schema_version",
      "integrity_check": "PRAGMA integrity_check"
    },
    "expected": {
      "library_count_approx": 801,
      "author_count_approx": 492
    },
    "upgrade": {
      "native_command": "./upgrade.sh --from-project . --remote 192.168.122.63 --yes",
      "docker_save_pattern": "docker save audiobook-manager:{version} | ssh -i ~/.ssh/id_ed25519 claude@192.168.122.63 'sudo docker load'"
    }
  }
}
