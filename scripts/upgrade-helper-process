#!/bin/bash
# =============================================================================
# Audiobooks Privileged Operations Helper
# =============================================================================
# This script runs as root when triggered by the path unit.
# It handles all operations requiring elevated privileges.
#
# Request file format (JSON):
#   Upgrade:     {"type": "upgrade", "source": "github"}
#                {"type": "upgrade", "source": "project", "project_path": "/path"}
#                {"type": "upgrade", "source": "github", "force": true, "version": "7.2.0", "major_version": false}
#   Check:       {"type": "upgrade_check", "source": "github"}
#                {"type": "upgrade_check", "source": "project", "project_path": "/path"}
#   Service:     {"type": "service_start", "service": "audiobook-converter"}
#                {"type": "service_stop", "service": "audiobook-converter"}
#                {"type": "service_restart", "service": "audiobook-api"}
#                {"type": "services_start_all"}
#                {"type": "services_stop_all", "include_api": false}
#
# Status file format (JSON):
#   {"running": true/false, "stage": "...", "message": "...", "success": true/false/null, "output": [...], "result": {...}}
#
# 9-Step Upgrade Lifecycle:
#   1. preflight_recheck   — validate preflight unless force=true
#   2. backing_up          — report stage (upgrade.sh handles actual backup)
#   3. stopping_services   — stop ALL 8 services in dependency order
#   4. upgrading           — run upgrade.sh --skip-service-lifecycle --yes
#   5. rebuilding_venv     — report stage (for major version upgrades)
#   6. migrating_config    — report stage (for major version upgrades)
#   [Write final result to status file HERE — before starting services]
#   7. starting_services   — start services in reverse order
#   8. verifying           — poll /api/system/health for up to 30s
#   9. complete            — update status with verification result
# =============================================================================

# Source audiobook-config.sh for path variables
# AUDIOBOOKS_HOME is set via EnvironmentFile in the systemd unit
source "${AUDIOBOOKS_HOME:-/opt/audiobooks}/lib/audiobook-config.sh" 2>/dev/null || true

# Control directory for API communication (using AUDIOBOOKS_VAR_DIR/.control/
# to avoid /run namespace issues with systemd sandboxing)
CONTROL_DIR="${AUDIOBOOKS_VAR_DIR:?}/.control"
REQUEST_FILE="${CONTROL_DIR}/upgrade-request"
STATUS_FILE="${CONTROL_DIR}/upgrade-status"
# Default install dir — config variable takes precedence if set
_DEFAULT_INSTALL_DIR="/opt/audiobooks"
INSTALL_DIR="${AUDIOBOOKS_INSTALL_DIR:-$_DEFAULT_INSTALL_DIR}"

# Valid services that can be controlled (all audiobook.target members)
VALID_SERVICES=(
    "audiobook-api"
    "audiobook-proxy"
    "audiobook-redirect"
    "audiobook-converter"
    "audiobook-mover"
    "audiobook-scheduler"
    "audiobook-shutdown-saver"
    "audiobook-downloader.timer"
)

# Ensure control directory exists and is writable by audiobooks user
mkdir -p "$CONTROL_DIR"
chown audiobooks:audiobooks "$CONTROL_DIR"
chmod 755 "$CONTROL_DIR"

# Global output array
declare -a OUTPUT_LINES

# Helper to write status
write_status() {
    local running="$1"
    local stage="$2"
    local message="$3"
    local success="$4"
    local result="${5:-null}"
    shift 5 2>/dev/null || shift 4
    local output_lines=("$@")

    # Build output JSON array
    local output_json="["
    local first=true
    for line in "${output_lines[@]}"; do
        if [[ "$first" == "true" ]]; then
            first=false
        else
            output_json+=","
        fi
        # Escape quotes and backslashes for JSON
        line="${line//\\/\\\\}"
        line="${line//\"/\\\"}"
        line="${line//$'\n'/\\n}"
        line="${line//$'\r'/}"
        output_json+="\"$line\""
    done
    output_json+="]"

    # Use echo with explicit file write (more reliable than heredoc in some environments)
    local status_json="{\"running\": $running, \"stage\": \"$stage\", \"message\": \"$message\", \"success\": $success, \"output\": $output_json, \"result\": $result}"
    echo "$status_json" >"$STATUS_FILE"
    # Make status file readable/writable by audiobooks group (API needs to read/delete it)
    chown root:audiobooks "$STATUS_FILE" 2>/dev/null || true
    chmod 660 "$STATUS_FILE" 2>/dev/null || true

    # Mirror to Caddy's static dir so maintenance.html can show live progress
    # even while the API is down (Caddy serves /etc/caddy/ during 502/503)
    echo "$status_json" >"/etc/caddy/upgrade-status.json" 2>/dev/null || true
    chmod 644 "/etc/caddy/upgrade-status.json" 2>/dev/null || true
}

# Check if service is valid
is_valid_service() {
    local svc="$1"
    for valid in "${VALID_SERVICES[@]}"; do
        [[ "$svc" == "$valid" ]] && return 0
    done
    return 1
}

# Parse JSON field (simple parser without jq)
get_json_field() {
    local json="$1"
    local field="$2"
    echo "$json" | grep -o "\"$field\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" | sed 's/.*:.*"\([^"]*\)".*/\1/' | head -1
}

get_json_bool() {
    local json="$1"
    local field="$2"
    local val=$(echo "$json" | grep -o "\"$field\"[[:space:]]*:[[:space:]]*[a-z]*" | sed 's/.*:[[:space:]]*//' | head -1)
    [[ "$val" == "true" ]] && echo "true" || echo "false"
}

# =============================================================================
# Service Control Operations
# =============================================================================

do_service_start() {
    local service="$1"

    if ! is_valid_service "$service"; then
        write_status "false" "complete" "Invalid service: $service" "false" "null" "${OUTPUT_LINES[@]}"
        return 1
    fi

    OUTPUT_LINES+=("Starting $service...")
    write_status "true" "processing" "Starting $service..." "null" "null" "${OUTPUT_LINES[@]}"

    if systemctl start "$service" 2>&1; then
        OUTPUT_LINES+=("Started $service")
        write_status "false" "complete" "Started $service" "true" "{\"service\": \"$service\", \"action\": \"start\"}" "${OUTPUT_LINES[@]}"
    else
        OUTPUT_LINES+=("Failed to start $service")
        write_status "false" "complete" "Failed to start $service" "false" "null" "${OUTPUT_LINES[@]}"
        return 1
    fi
}

do_service_stop() {
    local service="$1"

    if ! is_valid_service "$service"; then
        write_status "false" "complete" "Invalid service: $service" "false" "null" "${OUTPUT_LINES[@]}"
        return 1
    fi

    OUTPUT_LINES+=("Stopping $service...")
    write_status "true" "processing" "Stopping $service..." "null" "null" "${OUTPUT_LINES[@]}"

    if systemctl stop "$service" 2>&1; then
        OUTPUT_LINES+=("Stopped $service")
        write_status "false" "complete" "Stopped $service" "true" "{\"service\": \"$service\", \"action\": \"stop\"}" "${OUTPUT_LINES[@]}"
    else
        OUTPUT_LINES+=("Failed to stop $service")
        write_status "false" "complete" "Failed to stop $service" "false" "null" "${OUTPUT_LINES[@]}"
        return 1
    fi
}

do_service_restart() {
    local service="$1"

    if ! is_valid_service "$service"; then
        write_status "false" "complete" "Invalid service: $service" "false" "null" "${OUTPUT_LINES[@]}"
        return 1
    fi

    OUTPUT_LINES+=("Restarting $service...")
    write_status "true" "processing" "Restarting $service..." "null" "null" "${OUTPUT_LINES[@]}"

    if systemctl restart "$service" 2>&1; then
        OUTPUT_LINES+=("Restarted $service")
        write_status "false" "complete" "Restarted $service" "true" "{\"service\": \"$service\", \"action\": \"restart\"}" "${OUTPUT_LINES[@]}"
    else
        OUTPUT_LINES+=("Failed to restart $service")
        write_status "false" "complete" "Failed to restart $service" "false" "null" "${OUTPUT_LINES[@]}"
        return 1
    fi
}

do_services_start_all() {
    OUTPUT_LINES+=("Starting all services...")
    write_status "true" "processing" "Starting all services..." "null" "null" "${OUTPUT_LINES[@]}"

    local results="["
    local first=true
    local all_success=true

    for service in "${VALID_SERVICES[@]}"; do
        if systemctl start "$service" 2>&1; then
            OUTPUT_LINES+=("Started $service")
            [[ "$first" == "false" ]] && results+=","
            results+="{\"service\": \"$service\", \"success\": true}"
            first=false
        else
            OUTPUT_LINES+=("Failed to start $service")
            [[ "$first" == "false" ]] && results+=","
            results+="{\"service\": \"$service\", \"success\": false}"
            first=false
            all_success=false
        fi
    done

    results+="]"

    if [[ "$all_success" == "true" ]]; then
        write_status "false" "complete" "All services started" "true" "{\"results\": $results}" "${OUTPUT_LINES[@]}"
    else
        write_status "false" "complete" "Some services failed to start" "false" "{\"results\": $results}" "${OUTPUT_LINES[@]}"
    fi
}

do_services_stop_all() {
    local include_api="$1"

    OUTPUT_LINES+=("Stopping services (include_api=$include_api)...")
    write_status "true" "processing" "Stopping services..." "null" "null" "${OUTPUT_LINES[@]}"

    # Stop order: timer, mover, converter, then optionally proxy and api
    local stop_order=(
        "audiobook-downloader.timer"
        "audiobook-mover"
        "audiobook-converter"
    )

    if [[ "$include_api" == "true" ]]; then
        stop_order+=("audiobook-proxy" "audiobook-api")
    fi

    local results="["
    local first=true
    local all_success=true

    for service in "${stop_order[@]}"; do
        if systemctl stop "$service" 2>&1; then
            OUTPUT_LINES+=("Stopped $service")
            [[ "$first" == "false" ]] && results+=","
            results+="{\"service\": \"$service\", \"success\": true}"
            first=false
        else
            OUTPUT_LINES+=("Failed to stop $service (may not be running)")
            [[ "$first" == "false" ]] && results+=","
            results+="{\"service\": \"$service\", \"success\": false}"
            first=false
            # Don't mark as failure if service wasn't running
        fi
    done

    results+="]"

    local note="API and proxy services kept running for web access"
    [[ "$include_api" == "true" ]] && note="All services stopped"

    write_status "false" "complete" "$note" "true" "{\"results\": $results, \"note\": \"$note\"}" "${OUTPUT_LINES[@]}"
}

# =============================================================================
# Upgrade Operations
# =============================================================================

do_upgrade_check() {
    # Dry-run check: shows what would be upgraded without making changes
    local source="$1"
    local project_path="$2"

    OUTPUT_LINES+=("=== Upgrade Check (Dry Run) ===")
    OUTPUT_LINES+=("Source: $source")
    [[ -n "$project_path" ]] && OUTPUT_LINES+=("Project path: $project_path")

    write_status "true" "checking" "Checking for updates..." "null" "null" "${OUTPUT_LINES[@]}"

    local upgrade_script="$INSTALL_DIR/scripts/upgrade.sh"
    [[ ! -x "$upgrade_script" ]] && upgrade_script="/usr/local/bin/audiobook-upgrade"

    if [[ ! -x "$upgrade_script" ]]; then
        OUTPUT_LINES+=("ERROR: Upgrade script not found")
        write_status "false" "error" "Upgrade script not found" "false" "null" "${OUTPUT_LINES[@]}"
        return 1
    fi

    # Build upgrade command with --check (writes preflight report + shows changes)
    # Always pass --target to avoid unreliable auto-detection
    local upgrade_cmd
    if [[ "$source" == "github" ]]; then
        upgrade_cmd=("$upgrade_script" "--from-github" "--target" "$INSTALL_DIR" "--check")
    elif [[ "$source" == "project" ]] && [[ -n "$project_path" ]]; then
        if [[ ! -d "$project_path" ]]; then
            OUTPUT_LINES+=("ERROR: Project path does not exist: $project_path")
            write_status "false" "error" "Project path does not exist" "false" "null" "${OUTPUT_LINES[@]}"
            return 1
        fi
        upgrade_cmd=("$upgrade_script" "--from-project" "$project_path" "--target" "$INSTALL_DIR" "--check")
    else
        OUTPUT_LINES+=("ERROR: Invalid upgrade source")
        write_status "false" "error" "Invalid upgrade source" "false" "null" "${OUTPUT_LINES[@]}"
        return 1
    fi

    # Run upgrade check and capture output (no confirmation needed for dry-run)
    local check_output check_exit
    check_output=$("${upgrade_cmd[@]}" 2>&1)
    check_exit=$?

    # Parse output (strip ANSI codes)
    while IFS= read -r line; do
        local clean_line
        # shellcheck disable=SC2001  # \x1b regex not supported in bash parameter expansion
        clean_line=$(echo "$line" | sed 's/\x1b\[[0-9;]*m//g')
        [[ -n "$clean_line" ]] && OUTPUT_LINES+=("$clean_line")
    done <<<"$check_output"

    # Determine if upgrade is available from output
    local upgrade_available="false"
    local current_version=""
    local available_version=""

    # Extract version info from output
    for line in "${OUTPUT_LINES[@]}"; do
        if [[ "$line" =~ "Upgrade available" ]] || [[ "$line" =~ "→" ]] || [[ "$line" =~ "Successfully upgraded" ]]; then
            upgrade_available="true"
        fi
        if [[ "$line" =~ "Current version:" ]] || [[ "$line" =~ "Installed version:" ]]; then
            current_version=$(echo "$line" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
        fi
        if [[ "$line" =~ "Latest version:" ]] || [[ "$line" =~ "Project version:" ]] || [[ "$line" =~ "New version:" ]]; then
            available_version=$(echo "$line" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
        fi
    done

    # Also detect upgrade by comparing parsed versions
    if [[ -n "$current_version" ]] && [[ -n "$available_version" ]] && [[ "$current_version" != "$available_version" ]]; then
        upgrade_available="true"
    fi

    # Build result JSON
    local result_json="{\"upgrade_available\": $upgrade_available"
    [[ -n "$current_version" ]] && result_json+=", \"current_version\": \"$current_version\""
    [[ -n "$available_version" ]] && result_json+=", \"available_version\": \"$available_version\""
    result_json+=", \"source\": \"$source\""
    result_json+="}"

    if [[ $check_exit -ne 0 ]]; then
        # Non-zero exit might just mean "no upgrade needed" - check output
        if [[ "$check_output" =~ "Already at version" ]] || [[ "$check_output" =~ "No upgrade needed" ]] || [[ "$check_output" =~ "Versions are identical" ]]; then
            OUTPUT_LINES+=("No upgrade available")
            write_status "false" "complete" "Already up to date" "true" "$result_json" "${OUTPUT_LINES[@]}"
        else
            OUTPUT_LINES+=("Check failed with exit code: $check_exit")
            write_status "false" "error" "Check failed" "false" "$result_json" "${OUTPUT_LINES[@]}"
        fi
        return 0
    fi

    if [[ "$upgrade_available" == "true" ]]; then
        write_status "false" "complete" "Upgrade available: $current_version → $available_version" "true" "$result_json" "${OUTPUT_LINES[@]}"
    else
        write_status "false" "complete" "Already up to date" "true" "$result_json" "${OUTPUT_LINES[@]}"
    fi
}

do_upgrade() {
    local source="$1"
    local project_path="$2"
    local force="${3:-false}"
    local major_version="${4:-false}"
    local version="${5:-}"

    local upgrade_start_time=$SECONDS

    OUTPUT_LINES+=("Source: $source")
    [[ -n "$project_path" ]] && OUTPUT_LINES+=("Project path: $project_path")
    [[ "$force" == "true" ]] && OUTPUT_LINES+=("Force upgrade: yes")
    [[ "$major_version" == "true" ]] && OUTPUT_LINES+=("Major version upgrade: yes")
    [[ -n "$version" ]] && OUTPUT_LINES+=("Target version: $version")

    # Full stop order: all 8 services in dependency order (will be reversed on start)
    local services_stop_order=(
        "audiobook-downloader.timer"
        "audiobook-shutdown-saver"
        "audiobook-scheduler"
        "audiobook-mover"
        "audiobook-converter"
        "audiobook-redirect"
        "audiobook-proxy"
        "audiobook-api"
    )

    # =========================================================================
    # Step 1: preflight_recheck — validate preflight unless force=true
    # =========================================================================
    write_status "true" "preflight_recheck" "Rechecking preflight conditions..." "null" "null" "${OUTPUT_LINES[@]}"

    if [[ "$force" != "true" ]]; then
        local preflight_file="${CONTROL_DIR}/upgrade-preflight.json"
        if [[ ! -f "$preflight_file" ]]; then
            OUTPUT_LINES+=("WARNING: Preflight file missing — proceeding anyway (may have expired)")
        else
            OUTPUT_LINES+=("Preflight validated")
        fi
    else
        OUTPUT_LINES+=("Preflight skipped (force=true)")
    fi

    # =========================================================================
    # Step 2: backing_up — report stage (upgrade.sh handles actual backup)
    # =========================================================================
    write_status "true" "backing_up" "Creating backup before upgrade..." "null" "null" "${OUTPUT_LINES[@]}"
    OUTPUT_LINES+=("Backup stage: upgrade.sh will handle backup during upgrade")

    # =========================================================================
    # Step 3: stopping_services — stop ALL 8 services in dependency order
    # =========================================================================
    write_status "true" "stopping_services" "Stopping all services..." "null" "null" "${OUTPUT_LINES[@]}"

    for service in "${services_stop_order[@]}"; do
        if systemctl is-active --quiet "$service" 2>/dev/null; then
            systemctl stop "$service" 2>/dev/null || true
            OUTPUT_LINES+=("Stopped $service")
        else
            OUTPUT_LINES+=("Service $service was not running (skipped)")
        fi
    done

    write_status "true" "stopping_services" "All services stopped" "null" "null" "${OUTPUT_LINES[@]}"

    # =========================================================================
    # Step 4: upgrading — run upgrade.sh --skip-service-lifecycle --yes
    # =========================================================================
    write_status "true" "upgrading" "Running upgrade..." "null" "null" "${OUTPUT_LINES[@]}"

    local upgrade_script="$INSTALL_DIR/scripts/upgrade.sh"
    [[ ! -x "$upgrade_script" ]] && upgrade_script="/usr/local/bin/audiobook-upgrade"

    if [[ ! -x "$upgrade_script" ]]; then
        OUTPUT_LINES+=("ERROR: Upgrade script not found")
        # Write failure result BEFORE starting services (Status File Durability)
        write_status "false" "complete" "Upgrade failed: script not found" "false" "null" "${OUTPUT_LINES[@]}"
        # Start services back up even on failure
        write_status "true" "starting_services" "Restoring services after error..." "null" "null" "${OUTPUT_LINES[@]}"
        for ((i = ${#services_stop_order[@]} - 1; i >= 0; i--)); do
            systemctl start "${services_stop_order[i]}" 2>/dev/null || true
        done
        return 1
    fi

    # Build upgrade command — always pass --skip-service-lifecycle --yes
    # so upgrade.sh does not try to manage services (helper owns that)
    local upgrade_cmd
    if [[ "$source" == "github" ]]; then
        upgrade_cmd=("$upgrade_script" "--from-github" "--target" "$INSTALL_DIR" "--skip-service-lifecycle" "--yes")
    elif [[ "$source" == "project" ]] && [[ -n "$project_path" ]]; then
        if [[ ! -d "$project_path" ]]; then
            OUTPUT_LINES+=("ERROR: Project path does not exist: $project_path")
            # Write failure result BEFORE starting services (Status File Durability)
            write_status "false" "complete" "Upgrade failed: project path missing" "false" "null" "${OUTPUT_LINES[@]}"
            write_status "true" "starting_services" "Restoring services after error..." "null" "null" "${OUTPUT_LINES[@]}"
            for ((i = ${#services_stop_order[@]} - 1; i >= 0; i--)); do
                systemctl start "${services_stop_order[i]}" 2>/dev/null || true
            done
            return 1
        fi
        upgrade_cmd=("$upgrade_script" "--from-project" "$project_path" "--target" "$INSTALL_DIR" "--skip-service-lifecycle" "--yes")
    else
        OUTPUT_LINES+=("ERROR: Invalid upgrade source: $source")
        # Write failure result BEFORE starting services (Status File Durability)
        write_status "false" "complete" "Upgrade failed: invalid source" "false" "null" "${OUTPUT_LINES[@]}"
        write_status "true" "starting_services" "Restoring services after error..." "null" "null" "${OUTPUT_LINES[@]}"
        for ((i = ${#services_stop_order[@]} - 1; i >= 0; i--)); do
            systemctl start "${services_stop_order[i]}" 2>/dev/null || true
        done
        return 1
    fi

    # Add optional flags (per spec: --force, --major-version, --version X as applicable)
    [[ "$force" == "true" ]] && upgrade_cmd+=("--force")
    [[ "$major_version" == "true" ]] && upgrade_cmd+=("--major-version")
    [[ -n "$version" ]] && upgrade_cmd+=("--version" "$version")

    # Run upgrade and capture output
    local upgrade_output upgrade_exit
    upgrade_output=$("${upgrade_cmd[@]}" 2>&1)
    upgrade_exit=$?

    # Parse output (strip ANSI codes)
    while IFS= read -r line; do
        local clean_line
        # shellcheck disable=SC2001  # \x1b regex not supported in bash parameter expansion
        clean_line=$(echo "$line" | sed 's/\x1b\[[0-9;]*m//g')
        [[ -n "$clean_line" ]] && OUTPUT_LINES+=("$clean_line")
    done <<<"$upgrade_output"

    if [[ $upgrade_exit -ne 0 ]]; then
        OUTPUT_LINES+=("Upgrade script exited with code: $upgrade_exit")
        # Write failure result BEFORE starting services (Status File Durability)
        write_status "false" "complete" "Upgrade failed (exit code $upgrade_exit)" "false" "null" "${OUTPUT_LINES[@]}"
        # Start services back up even on failure
        write_status "true" "starting_services" "Restoring services after upgrade failure..." "null" "null" "${OUTPUT_LINES[@]}"
        for ((i = ${#services_stop_order[@]} - 1; i >= 0; i--)); do
            systemctl start "${services_stop_order[i]}" 2>/dev/null || true
        done
        return 1
    fi

    OUTPUT_LINES+=("Upgrade script completed successfully")
    write_status "true" "upgrading" "Upgrade completed" "null" "null" "${OUTPUT_LINES[@]}"

    # =========================================================================
    # Step 5: rebuilding_venv — report stage (especially for major version)
    # =========================================================================
    write_status "true" "rebuilding_venv" "Rebuilding virtual environment..." "null" "null" "${OUTPUT_LINES[@]}"
    if [[ "$major_version" == "true" ]]; then
        OUTPUT_LINES+=("Major version upgrade: venv rebuilt by upgrade.sh")
    else
        OUTPUT_LINES+=("Virtual environment updated")
    fi

    # =========================================================================
    # Step 6: migrating_config — report stage (for major version upgrades)
    # =========================================================================
    write_status "true" "migrating_config" "Checking configuration migration..." "null" "null" "${OUTPUT_LINES[@]}"
    if [[ "$major_version" == "true" ]]; then
        OUTPUT_LINES+=("Major version upgrade: configuration migration handled by upgrade.sh")
    else
        OUTPUT_LINES+=("Configuration unchanged")
    fi

    # Extract version info from output
    local new_version=""
    local old_version=""
    for line in "${OUTPUT_LINES[@]}"; do
        if [[ "$line" =~ "Successfully upgraded" ]] || [[ "$line" =~ "→" ]]; then
            new_version=$(echo "$line" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+(\.[0-9]+)?' | tail -1)
            old_version=$(echo "$line" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1)
        fi
    done

    local upgrade_duration=$((SECONDS - upgrade_start_time))

    # =========================================================================
    # CRITICAL: Write final upgrade result BEFORE starting services
    # Per spec "Status File Durability": result must be readable even if API
    # startup fails. The browser polls this file — it must persist the result.
    # =========================================================================
    local result_json="{\"upgrade_result\": \"success\", \"duration_seconds\": $upgrade_duration"
    [[ -n "$new_version" ]] && result_json+=", \"new_version\": \"$new_version\""
    [[ -n "$old_version" ]] && result_json+=", \"old_version\": \"$old_version\""
    result_json+=", \"source\": \"$source\""
    result_json+="}"

    write_status "false" "complete" "Upgrade completed successfully — starting services" "true" "$result_json" "${OUTPUT_LINES[@]}"

    # =========================================================================
    # Step 7: starting_services — start in reverse order
    # =========================================================================
    write_status "true" "starting_services" "Starting services..." "null" "null" "${OUTPUT_LINES[@]}"

    for ((i = ${#services_stop_order[@]} - 1; i >= 0; i--)); do
        local service="${services_stop_order[i]}"
        if systemctl start "$service" 2>/dev/null; then
            OUTPUT_LINES+=("Started $service")
        else
            OUTPUT_LINES+=("Warning: failed to start $service")
        fi
    done

    write_status "true" "starting_services" "Services started" "null" "null" "${OUTPUT_LINES[@]}"

    # =========================================================================
    # Step 8: verifying — poll /api/system/health for up to 30s
    # =========================================================================
    write_status "true" "verifying" "Verifying API is healthy..." "null" "null" "${OUTPUT_LINES[@]}"

    local api_port="${AUDIOBOOKS_API_PORT:-5001}"
    local verify_ok=false
    local max_wait=30
    local elapsed=0

    while [[ $elapsed -lt $max_wait ]]; do
        if curl -sf "http://127.0.0.1:${api_port}/api/system/health" >/dev/null 2>&1; then
            verify_ok=true
            break
        fi
        sleep 2
        elapsed=$((elapsed + 2))
    done

    # =========================================================================
    # Step 9: complete — update status with verification result
    # =========================================================================
    if [[ "$verify_ok" == "true" ]]; then
        OUTPUT_LINES+=("API health check passed after ${elapsed}s")
        write_status "false" "complete" "Upgrade completed successfully — API is healthy" "true" "$result_json" "${OUTPUT_LINES[@]}"
    else
        OUTPUT_LINES+=("WARNING: API health check did not pass within ${max_wait}s (may still be starting)")
        write_status "false" "complete" "Upgrade completed — API may need a moment to start" "true" "$result_json" "${OUTPUT_LINES[@]}"
    fi

    # Clean up Caddy status file after a brief delay (maintenance.html will have
    # already reloaded by now since the API is back up)
    sleep 5
    rm -f "/etc/caddy/upgrade-status.json" 2>/dev/null || true
}

# =============================================================================
# Main Entry Point
# =============================================================================

# Initialize status
write_status "true" "starting" "Processing request..." "null" "null"

# Check for request file
if [[ ! -f "$REQUEST_FILE" ]]; then
    write_status "false" "error" "No request found" "false" "null"
    exit 1
fi

# Read and parse request
REQUEST=$(cat "$REQUEST_FILE")
REQUEST_TYPE=$(get_json_field "$REQUEST" "type")

# Default type is "upgrade" for backwards compatibility
[[ -z "$REQUEST_TYPE" ]] && REQUEST_TYPE="upgrade"

case "$REQUEST_TYPE" in
upgrade)
    SOURCE=$(get_json_field "$REQUEST" "source")
    PROJECT_PATH=$(get_json_field "$REQUEST" "project_path")
    FORCE=$(get_json_bool "$REQUEST" "force")
    MAJOR_VERSION=$(get_json_bool "$REQUEST" "major_version")
    VERSION=$(get_json_field "$REQUEST" "version")
    [[ -z "$SOURCE" ]] && SOURCE="github"
    do_upgrade "$SOURCE" "$PROJECT_PATH" "$FORCE" "$MAJOR_VERSION" "$VERSION"
    ;;

upgrade_check)
    SOURCE=$(get_json_field "$REQUEST" "source")
    PROJECT_PATH=$(get_json_field "$REQUEST" "project_path")
    [[ -z "$SOURCE" ]] && SOURCE="github"
    do_upgrade_check "$SOURCE" "$PROJECT_PATH"
    ;;

service_start)
    SERVICE=$(get_json_field "$REQUEST" "service")
    do_service_start "$SERVICE"
    ;;

service_stop)
    SERVICE=$(get_json_field "$REQUEST" "service")
    do_service_stop "$SERVICE"
    ;;

service_restart)
    SERVICE=$(get_json_field "$REQUEST" "service")
    do_service_restart "$SERVICE"
    ;;

services_start_all)
    do_services_start_all
    ;;

services_stop_all)
    INCLUDE_API=$(get_json_bool "$REQUEST" "include_api")
    do_services_stop_all "$INCLUDE_API"
    ;;

*)
    write_status "false" "error" "Unknown request type: $REQUEST_TYPE" "false" "null"
    exit 1
    ;;
esac

exit 0
