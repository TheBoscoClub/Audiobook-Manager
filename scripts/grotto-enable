#!/bin/bash
# =============================================================================
# Enable Vox Grotto Conversion Auto-start on Boot
# =============================================================================

GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}Enabling Vox Grotto conversion auto-start...${NC}"
echo ""

# Reload systemd
systemctl daemon-reload

# Enable services
systemctl enable grotto-converter.service
systemctl enable grotto-mover.service

echo ""
echo -e "${GREEN}✓ Auto-start enabled${NC}"
echo ""
echo "Services will start automatically on boot."
echo "Start now with: grotto-start"
