#!/bin/bash
# =============================================================================
# Audiobook Library - Cloudflare Cache Purge
# =============================================================================
# Purges the Cloudflare CDN cache for the library domain.
# Call after deploying CSS/JS/HTML changes to ensure visitors get fresh assets.
#
# Setup:
#   1. Create a Cloudflare API Token with Zone > Cache Purge > Purge permission
#   2. Save it: echo "YOUR_TOKEN" | sudo tee /etc/audiobooks/cloudflare-api-token
#   3. Secure it: sudo chmod 600 /etc/audiobooks/cloudflare-api-token
#                 sudo chown audiobooks:audiobooks /etc/audiobooks/cloudflare-api-token
#
# Usage:
#   audiobook-purge-cache              # Purge everything
#   audiobook-purge-cache --files URL  # Purge specific URLs (comma-separated)
#   audiobook-purge-cache --quiet      # Suppress output (for use in scripts)
# =============================================================================

set -e

# Load config
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"
if [[ -f "$LIB_DIR/audiobook-config.sh" ]]; then
    source "$LIB_DIR/audiobook-config.sh"
elif [[ -f /usr/local/lib/audiobooks/audiobook-config.sh ]]; then
    source /usr/local/lib/audiobooks/audiobook-config.sh
fi

# Cloudflare configuration
CF_TOKEN_FILE="${CF_TOKEN_FILE:-/etc/audiobooks/cloudflare-api-token}"
CF_ZONE_ID="${CF_ZONE_ID:-}"
QUIET=false
PURGE_FILES=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --files) PURGE_FILES="$2"; shift 2 ;;
        --quiet|-q) QUIET=true; shift ;;
        --help|-h)
            echo "Usage: audiobook-purge-cache [--files URL,...] [--quiet]"
            echo ""
            echo "Purges Cloudflare CDN cache for the library domain."
            echo ""
            echo "Options:"
            echo "  --files URL,...   Purge specific URLs (comma-separated)"
            echo "  --quiet, -q      Suppress output"
            echo "  --help, -h       Show this help"
            echo ""
            echo "Environment:"
            echo "  CF_TOKEN_FILE    Path to API token file (default: /etc/audiobooks/cloudflare-api-token)"
            echo "  CF_ZONE_ID       Cloudflare zone ID (default: auto-detected from config)"
            exit 0
            ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

# Check for API token
if [[ ! -f "$CF_TOKEN_FILE" ]]; then
    if [[ "$QUIET" == "false" ]]; then
        echo "Cloudflare API token not found at $CF_TOKEN_FILE"
        echo ""
        echo "Setup instructions:"
        echo "  1. Go to https://dash.cloudflare.com → My Profile → API Tokens"
        echo "  2. Create token with: Zone > Cache Purge > Purge (for thebosco.club)"
        echo "  3. Save it:"
        echo "     echo \"YOUR_TOKEN\" | sudo tee $CF_TOKEN_FILE"
        echo "     sudo chmod 600 $CF_TOKEN_FILE"
        echo "     sudo chown audiobooks:audiobooks $CF_TOKEN_FILE"
    fi
    exit 1
fi

CF_TOKEN=$(cat "$CF_TOKEN_FILE")
if [[ -z "$CF_TOKEN" ]]; then
    [[ "$QUIET" == "false" ]] && echo "Error: Token file is empty"
    exit 1
fi

# Auto-detect zone ID if not set
if [[ -z "$CF_ZONE_ID" ]]; then
    # Use the hostname from config to look up the zone
    domain="${AUDIOBOOKS_HOSTNAME:-library.thebosco.club}"
    # Extract the root domain (last two parts)
    root_domain=$(echo "$domain" | awk -F. '{print $(NF-1)"."$NF}')

    if [[ "$QUIET" == "false" ]]; then
        echo "Looking up Cloudflare zone for $root_domain..."
    fi

    zone_response=$(curl -s -X GET "https://api.cloudflare.com/client/v4/zones?name=$root_domain" \
        -H "Authorization: Bearer $CF_TOKEN" \
        -H "Content-Type: application/json")

    CF_ZONE_ID=$(echo "$zone_response" | python3 -c "
import sys, json
data = json.load(sys.stdin)
if data.get('success') and data.get('result'):
    print(data['result'][0]['id'])
else:
    print('')
" 2>/dev/null)

    if [[ -z "$CF_ZONE_ID" ]]; then
        [[ "$QUIET" == "false" ]] && echo "Error: Could not find Cloudflare zone for $root_domain"
        [[ "$QUIET" == "false" ]] && echo "Set CF_ZONE_ID manually or check your API token permissions"
        exit 1
    fi

    if [[ "$QUIET" == "false" ]]; then
        echo "Found zone: $CF_ZONE_ID"
    fi
fi

# Build purge request
if [[ -n "$PURGE_FILES" ]]; then
    # Purge specific files
    # Convert comma-separated URLs to JSON array
    files_json=$(echo "$PURGE_FILES" | python3 -c "
import sys, json
urls = [u.strip() for u in sys.stdin.read().strip().split(',') if u.strip()]
print(json.dumps({'files': urls}))
")
    purge_type="specific files"
else
    # Purge everything
    files_json='{"purge_everything":true}'
    purge_type="everything"
fi

if [[ "$QUIET" == "false" ]]; then
    echo "Purging $purge_type from Cloudflare cache..."
fi

response=$(curl -s -X POST "https://api.cloudflare.com/client/v4/zones/$CF_ZONE_ID/purge_cache" \
    -H "Authorization: Bearer $CF_TOKEN" \
    -H "Content-Type: application/json" \
    --data "$files_json")

success=$(echo "$response" | python3 -c "
import sys, json
data = json.load(sys.stdin)
print('true' if data.get('success') else 'false')
" 2>/dev/null)

if [[ "$success" == "true" ]]; then
    [[ "$QUIET" == "false" ]] && echo "Cache purged successfully"
    exit 0
else
    if [[ "$QUIET" == "false" ]]; then
        echo "Cache purge failed:"
        echo "$response" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for err in data.get('errors', []):
    print(f\"  {err.get('code', '?')}: {err.get('message', 'Unknown error')}\")
" 2>/dev/null || echo "  $response"
    fi
    exit 1
fi
