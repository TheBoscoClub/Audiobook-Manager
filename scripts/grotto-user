#!/bin/bash
# Vox Grotto Library User Management CLI
# Wrapper script — manage authenticated users for multi-user access
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "${SCRIPT_DIR}/../lib/grotto-config.sh"
exec "$(audiobooks_python)" "${AUDIOBOOKS_HOME}/library/auth/cli.py" \
	--database "${AUTH_DATABASE:-${AUDIOBOOKS_VAR_DIR}/auth.db}" \
	--key-file "${AUTH_KEY_FILE:-/etc/audiobooks/auth.key}" \
	"$@"
