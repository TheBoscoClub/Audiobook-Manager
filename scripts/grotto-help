#!/bin/bash
# =============================================================================
# Vox Grotto Conversion System - Quick Reference Guide
# =============================================================================

# Source config to resolve path variables (optional — falls back to defaults)
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
if [[ -f "${SCRIPT_DIR}/../lib/grotto-config.sh" ]]; then
    source "${SCRIPT_DIR}/../lib/grotto-config.sh" 2>/dev/null
elif [[ -f "/opt/audiobooks/lib/grotto-config.sh" ]]; then
    source "/opt/audiobooks/lib/grotto-config.sh" 2>/dev/null
fi

cat <<EOF
╔════════════════════════════════════════════════════════════╗
║         VOX GROTTO CONVERSION SYSTEM - QUICK GUIDE          ║
╚════════════════════════════════════════════════════════════╝

📊 MONITORING & STATUS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  grotto-status              Full system status
  monitor-grotto-conversion  Live progress monitor (auto-refresh)

🎮 CONTROL COMMANDS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  grotto-start               Start conversion manually
  grotto-stop                Stop conversion
  grotto-enable              Enable auto-start on boot
  grotto-disable             Disable auto-start

💾 DATA MANAGEMENT
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  grotto-save-staging        Save staged files before reboot
  grotto-download           Download new audiobooks from Audible

📁 DIRECTORIES
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Sources:    $AUDIOBOOKS_SOURCES   (AAXC files from Audible)
  Staging:    /tmp/audiobook-staging   (tmpfs, fast conversion)
  Library:    $AUDIOBOOKS_LIBRARY   (final converted files)

⚙️ SERVICES
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  grotto-converter    Converts AAXC to Opus (8 parallel jobs)
  grotto-mover        Moves completed files to library
  grotto-downloader   Downloads new audiobooks periodically
  grotto-api          Web API for library browsing

📖 MORE INFORMATION
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Configuration:  /etc/audiobooks/audiobooks.conf
  Logs:           $AUDIOBOOKS_LOGS
  Project:        $AUDIOBOOKS_HOME

EOF
