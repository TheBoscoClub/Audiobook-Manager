#!/bin/bash
# Audiobook Translation Management
#
# Unified CLI for translation queue control and asset transfer.
#
# Queue control:
#   audiobook-translations status              # Show queue state + stream-translate service
#   audiobook-translations pause               # Pause queue (finish in-progress, stop new)
#   audiobook-translations resume              # Resume paused queue
#   audiobook-translations report [options]    # On-demand report of all completed translations
#
# Asset transfer:
#   audiobook-translations export -o translations.tar.gz [--locale zh-Hans]
#   audiobook-translations import -a translations.tar.gz
#
# Backlog translation work is dispatched on-demand via `scripts/batch-translate.py`
# against serverless STT endpoints (RunPod + Vast.ai serverless) — there is no
# dedicated translation daemon to start/stop; the queue is drained by whichever
# process invokes batch-translate.py.
#
# Streaming translation runs as audiobook-stream-translate.service (always-on).
#
# The --db flag defaults to $AUDIOBOOKS_DATABASE from audiobooks.conf.
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "${SCRIPT_DIR}/../lib/audiobook-config.sh"

export AUDIOBOOKS_DATABASE="${AUDIOBOOKS_DATABASE:-/var/lib/audiobooks/db/audiobooks.db}"
DB="$AUDIOBOOKS_DATABASE"

# Wrap sqlite3 so every read tolerates transient write locks from the daemon's
# workers. Without busy_timeout, a locked DB returns instantly with "database
# is locked" on stderr, and callers that silence stderr see an empty string —
# which previously rendered as "Queue: empty" even when 1800+ jobs existed.
sq() {
    sqlite3 -cmd ".timeout 5000" "$DB" "$@"
}

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

usage() {
    echo "Usage: audiobook-translations <command> [options]"
    echo ""
    echo "Queue control:"
    echo "  status              Show translation queue state and stream-translate service status"
    echo "  status --watch [N]  Auto-refresh every N seconds (default 5); interactive keys +/-/q"
    echo "  pause     Pause queue (in-progress books finish, no new ones start)"
    echo "  resume    Resume paused translations"
    echo "  report    On-demand report of all completed translations"
    echo "            Options: --locale LOCALE  --since DATE  --csv  --no-summary"
    echo ""
    echo "Asset transfer:"
    echo "  export    Export translation assets to archive"
    echo "  import    Import translation assets from archive"
    echo ""
    echo "Run 'audiobook-translations <command> --help' for command-specific options."
}

cmd_status() {
    echo -e "${BLUE}Translation Queue Status${NC}  $(date '+%Y-%m-%d %H:%M:%S')"
    echo "─────────────────────────────────────"

    if [[ ! -f "$DB" ]]; then
        echo -e "${RED}Database not found: $DB${NC}"
        exit 1
    fi

    # Queue counts by state
    local states pending_count processing_count
    states=$(sq "SELECT state, COUNT(*) FROM translation_queue GROUP BY state ORDER BY state;" 2>/dev/null)
    pending_count=0
    processing_count=0
    if [[ -z "$states" ]]; then
        echo "  Queue: empty (no translation jobs)"
    else
        while IFS='|' read -r state count; do
            case "$state" in
                completed) echo -e "  ${GREEN}${state}${NC}: ${count}" ;;
                processing)
                    echo -e "  ${BLUE}${state}${NC}: ${count}"
                    processing_count="$count"
                    ;;
                pending)
                    echo -e "  ${YELLOW}${state}${NC}: ${count}"
                    pending_count="$count"
                    ;;
                paused) echo -e "  ${YELLOW}${state} (frozen)${NC}: ${count}" ;;
                failed) echo -e "  ${RED}${state}${NC}: ${count}" ;;
                *) echo "  ${state}: ${count}" ;;
            esac
        done <<<"$states"
    fi

    # In-progress details: title, step, chapters done, elapsed time
    if [[ "${processing_count:-0}" -gt 0 ]]; then
        echo ""
        echo -e "${BLUE}In progress:${NC}"
        # chapter_subtitles rows for locale='en' exist once STT finishes a chapter,
        # so per-book en count approximates "chapters transcribed so far".
        # Titles print in full — the terminal wraps if they exceed the width.
        local rows
        rows=$(sq -separator $'\t' "
            SELECT tq.audiobook_id,
                   tq.step,
                   COALESCE(cs.ch_count, 0),
                   COALESCE(tq.total_chapters, 0),
                   CAST((strftime('%s','now') - strftime('%s', tq.started_at)) AS INTEGER),
                   CAST((strftime('%s','now') - strftime('%s', COALESCE(tq.last_progress_at, tq.started_at))) AS INTEGER),
                   a.title
            FROM translation_queue tq
            JOIN audiobooks a ON a.id = tq.audiobook_id
            LEFT JOIN (
                SELECT audiobook_id, COUNT(*) AS ch_count
                FROM chapter_subtitles
                WHERE locale = 'en'
                GROUP BY audiobook_id
            ) cs ON cs.audiobook_id = tq.audiobook_id
            WHERE tq.state = 'processing'
            ORDER BY tq.started_at
            LIMIT 20;
        " 2>/dev/null)
        if [[ -n "$rows" ]]; then
            printf "  %-7s %-7s %-13s %-9s %-7s %s\n" "STEP" "ID" "PROGRESS" "ELAPSED" "IDLE" "TITLE"
            while IFS=$'\t' read -r bid step chapters total elapsed idle title; do
                local progress
                if [[ "${total:-0}" -gt 0 ]]; then
                    local pct=$((chapters * 100 / total))
                    progress=$(printf "%d/%d (%d%%)" "$chapters" "$total" "$pct")
                elif [[ "${chapters:-0}" -gt 0 ]]; then
                    progress=$(printf "%d ch" "$chapters")
                else
                    progress="—"
                fi
                local el_fmt
                if [[ "$elapsed" -ge 3600 ]]; then
                    el_fmt=$(printf "%dh%02dm" $((elapsed / 3600)) $(((elapsed % 3600) / 60)))
                else
                    el_fmt=$(printf "%02d:%02d" $((elapsed / 60)) $((elapsed % 60)))
                fi
                local idle_fmt idle_color="${NC}"
                if [[ "$idle" -ge 3600 ]]; then
                    idle_fmt=$(printf "%dh%02dm" $((idle / 3600)) $(((idle % 3600) / 60)))
                    idle_color="${RED}"
                elif [[ "$idle" -ge 900 ]]; then
                    idle_fmt=$(printf "%02d:%02d" $((idle / 60)) $((idle % 60)))
                    idle_color="${YELLOW}"
                else
                    idle_fmt=$(printf "%02d:%02d" $((idle / 60)) $((idle % 60)))
                fi
                printf "  %-7s %-7s %-13s %-9s ${idle_color}%-7s${NC} %s\n" \
                    "$step" "#$bid" "$progress" "$el_fmt" "$idle_fmt" "$title"
            done <<<"$rows"
        fi

        # ETA calculation — avg per-book completion time × pending ÷ active workers
        local avg_sec
        avg_sec=$(sq "
            SELECT CAST(AVG(strftime('%s', finished_at) - strftime('%s', started_at)) AS INTEGER)
            FROM translation_queue
            WHERE state = 'completed'
              AND started_at IS NOT NULL
              AND finished_at IS NOT NULL;
        " 2>/dev/null)
        if [[ -n "$avg_sec" && "$avg_sec" -gt 0 && "${pending_count:-0}" -gt 0 ]]; then
            local eta_sec workers avg_min
            workers=${processing_count:-1}
            eta_sec=$((pending_count * avg_sec / workers))
            avg_min=$((avg_sec / 60))
            local eta_fmt
            if [[ "$eta_sec" -ge 86400 ]]; then
                eta_fmt=$(printf "~%dd %02dh" $((eta_sec / 86400)) $(((eta_sec % 86400) / 3600)))
            elif [[ "$eta_sec" -ge 3600 ]]; then
                eta_fmt=$(printf "~%dh %02dm" $((eta_sec / 3600)) $(((eta_sec % 3600) / 60)))
            else
                eta_fmt=$(printf "~%dm" $((eta_sec / 60)))
            fi
            echo ""
            echo -e "  ${BLUE}ETA${NC}: ${eta_fmt} (${pending_count} pending × ~${avg_min}min/book ÷ ${workers} workers)"
        fi
    fi

    # Subtitle counts
    local en_chapters zh_chapters en_books zh_books
    en_chapters=$(sq "SELECT COUNT(*) FROM chapter_subtitles WHERE locale='en';" 2>/dev/null)
    zh_chapters=$(sq "SELECT COUNT(*) FROM chapter_subtitles WHERE locale='zh-Hans';" 2>/dev/null)
    en_books=$(sq "SELECT COUNT(DISTINCT audiobook_id) FROM chapter_subtitles WHERE locale='en';" 2>/dev/null)
    zh_books=$(sq "SELECT COUNT(DISTINCT audiobook_id) FROM chapter_subtitles WHERE locale='zh-Hans';" 2>/dev/null)

    echo ""
    echo "Subtitles:"
    echo "  English:  ${en_chapters:-0} chapters across ${en_books:-0} books"
    echo "  zh-Hans:  ${zh_chapters:-0} chapters across ${zh_books:-0} books"

    # Stream-translate service status (streaming playback pipeline)
    echo ""
    echo "Streaming translation service:"
    if systemctl is-active --quiet audiobook-stream-translate.service 2>/dev/null; then
        echo -e "  Service: ${GREEN}active${NC}"
        local pid
        pid=$(systemctl show audiobook-stream-translate.service --property=MainPID --value 2>/dev/null)
        [[ -n "$pid" && "$pid" != "0" ]] && echo "  PID: $pid"
    else
        echo -e "  Service: ${YELLOW}inactive${NC}"
    fi

    # Note: backlog queue drainage is on-demand (scripts/batch-translate.py) —
    # there is no always-on translation daemon to poll. WATCH_TICK_INTERVAL is
    # informational only (display refresh cadence).
    if [[ -n "${WATCH_TICK_INTERVAL:-}" ]]; then
        echo -e "  ${YELLOW}--watch${NC}: display refresh every ${WATCH_TICK_INTERVAL}s"
    fi
}

cmd_pause() {
    if [[ ! -f "$DB" ]]; then
        echo -e "${RED}Database not found: $DB${NC}"
        exit 1
    fi

    local pending
    pending=$(sq "SELECT COUNT(*) FROM translation_queue WHERE state='pending';" 2>/dev/null)
    local processing
    processing=$(sq "SELECT COUNT(*) FROM translation_queue WHERE state='processing';" 2>/dev/null)

    if [[ "${pending:-0}" -eq 0 ]]; then
        local paused
        paused=$(sq "SELECT COUNT(*) FROM translation_queue WHERE state='paused';" 2>/dev/null)
        if [[ "${paused:-0}" -gt 0 ]]; then
            echo -e "${YELLOW}Queue is already paused (${paused} paused jobs)${NC}"
        else
            echo "No pending translations to pause."
        fi
        [[ "${processing:-0}" -gt 0 ]] && echo -e "${BLUE}${processing} books still processing — they will finish naturally.${NC}"
        return 0
    fi

    sq "UPDATE translation_queue SET state = 'paused' WHERE state = 'pending';"
    echo -e "${GREEN}Paused ${pending} pending translations.${NC}"
    [[ "${processing:-0}" -gt 0 ]] && echo -e "${BLUE}${processing} books still processing — they will finish, then the daemon stops.${NC}"
    echo ""
    echo "Resume with: audiobook-translations resume"
}

cmd_resume() {
    if [[ ! -f "$DB" ]]; then
        echo -e "${RED}Database not found: $DB${NC}"
        exit 1
    fi

    local paused
    paused=$(sq "SELECT COUNT(*) FROM translation_queue WHERE state='paused';" 2>/dev/null)

    if [[ "${paused:-0}" -eq 0 ]]; then
        echo "No paused translations to resume."
        return 0
    fi

    sq "UPDATE translation_queue SET state = 'pending' WHERE state = 'paused';"
    echo -e "${GREEN}Resumed ${paused} translations.${NC}"
    echo "Run: sudo /opt/audiobooks/library/venv/bin/python /opt/audiobooks/scripts/batch-translate.py"
    echo "     to drain pending jobs against serverless STT endpoints."
}

# Run cmd_status in a refresh loop until SIGINT. Default interval 5s; override
# via --watch=N or -wN. Clears the screen each tick so the display doesn't
# grow without bound; trap SIGINT so Ctrl+C exits cleanly without a traceback.
#
# Interactive keys (via `read -t` instead of sleep):
#   +/= : increase refresh interval by STEP seconds
#   -/_ : decrease refresh interval by STEP seconds (floor 1s)
#   r   : refresh immediately
#   q   : quit
cmd_status_watch() {
    local interval="${1:-5}"
    local step=5
    local tick=0
    local last_ts=0
    local now_ts=0
    local observed=0
    if ! [[ "$interval" =~ ^[0-9]+$ ]] || [[ "$interval" -lt 1 ]]; then
        echo -e "${RED}Invalid interval: $interval${NC}" >&2
        exit 1
    fi
    # Hold the controlling tty in non-canonical (cbreak) mode for the life of
    # the loop so +/-/r/q are delivered to read() immediately. Bash's
    # `read -n1` only flips the tty while blocked in read(); keys typed during
    # the cmd_status render window sit in the line-discipline buffer and are
    # dropped. Holding cbreak across the whole loop fixes that.
    local _stty_saved=""
    if [[ -t 0 ]]; then
        _stty_saved=$(stty -g 2>/dev/null || true)
    fi
    _restore_tty() { [[ -n "$_stty_saved" ]] && stty "$_stty_saved" 2>/dev/null || true; }
    trap '_restore_tty; printf "\n"; exit 0' INT
    trap '_restore_tty' EXIT
    [[ -n "$_stty_saved" ]] && stty -icanon -echo min 0 time 0 2>/dev/null || true
    while true; do
        tick=$((tick + 1))
        now_ts=$(date +%s)
        if [[ "$last_ts" -gt 0 ]]; then
            observed=$((now_ts - last_ts))
        else
            observed=0
        fi
        last_ts=$now_ts
        tput clear 2>/dev/null || clear
        WATCH_TICK_INTERVAL="$interval" cmd_status
        echo ""
        local observed_label=""
        if [[ "$observed" -gt 0 ]]; then
            observed_label=" (last tick ${observed}s ago)"
        fi
        echo -e "${BLUE}Tick #${tick} @ $(date '+%H:%M:%S')  interval=${interval}s${observed_label}${NC}"
        echo -e "${BLUE}keys: +/- (±${step}s)  r=refresh now  q=quit${NC}"
        local key=""
        if read -rsn1 -t "$interval" key 2>/dev/null; then
            case "$key" in
                + | =) interval=$((interval + step)) ;;
                - | _)
                    interval=$((interval - step))
                    [[ "$interval" -lt 1 ]] && interval=1
                    ;;
                r | R) : ;;
                q | Q)
                    printf "\n"
                    exit 0
                    ;;
            esac
        fi
    done
}

# On-demand report of completed translations. Unlike `status`, which is a
# live daemon dashboard, `report` is a historical audit — "what did the
# pipeline actually deliver?" — suitable for release notes, cost attribution,
# and verifying a locale rollout finished.
#
# Columns: audiobook title+author, locale, chapter count (actual VTT rows in
# chapter_subtitles), wall-clock duration (finished_at − started_at), and
# finish timestamp. Falls back gracefully when started_at is NULL on rows
# imported from older schema versions.
#
# Options:
#   --locale LOCALE   Filter to a single locale (e.g. zh-Hans)
#   --since DATE      Only rows with finished_at >= DATE (YYYY-MM-DD or ISO-8601)
#   --csv             CSV output for spreadsheet import
#   --no-summary      Suppress trailing summary line
cmd_report() {
    local locale_filter="" since_filter="" fmt="human" show_summary=1
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --locale)
                locale_filter="$2"
                shift 2
                ;;
            --locale=*)
                locale_filter="${1#*=}"
                shift
                ;;
            --since)
                since_filter="$2"
                shift 2
                ;;
            --since=*)
                since_filter="${1#*=}"
                shift
                ;;
            --csv)
                fmt="csv"
                shift
                ;;
            --no-summary)
                show_summary=0
                shift
                ;;
            -h | --help)
                cat <<'EOF'
Usage: audiobook-translations report [options]

On-demand report of all completed translations.

Options:
  --locale LOCALE   Filter to a single locale (e.g. zh-Hans)
  --since DATE      Only include translations finished on/after DATE
                    (YYYY-MM-DD or full ISO-8601 timestamp)
  --csv             Emit CSV (title,author,locale,chapters,duration_sec,finished_at)
  --no-summary      Omit the trailing totals line
EOF
                return 0
                ;;
            *)
                echo -e "${RED}Unknown option for report: $1${NC}" >&2
                return 1
                ;;
        esac
    done

    if [[ ! -f "$DB" ]]; then
        echo -e "${RED}Database not found: $DB${NC}" >&2
        return 1
    fi

    local where="tq.state = 'completed'"
    [[ -n "$locale_filter" ]] && where="${where} AND tq.locale = '$(printf '%s' "$locale_filter" | sed "s/'/''/g")'"
    [[ -n "$since_filter" ]] && where="${where} AND tq.finished_at >= '$(printf '%s' "$since_filter" | sed "s/'/''/g")'"

    # Per-row detail. chapter_subtitles is the canonical per-chapter record;
    # COUNT(DISTINCT) handles multi-provider rows for the same chapter.
    local rows
    rows=$(sq "\
        SELECT \
            COALESCE(a.title, '(unknown #' || tq.audiobook_id || ')') AS title, \
            COALESCE(a.author, '—') AS author, \
            tq.locale, \
            (SELECT COUNT(DISTINCT chapter_index) FROM chapter_subtitles \
             WHERE audiobook_id = tq.audiobook_id AND locale = tq.locale) AS chapters, \
            CASE WHEN tq.started_at IS NOT NULL AND tq.finished_at IS NOT NULL \
                 THEN CAST(strftime('%s', tq.finished_at) - strftime('%s', tq.started_at) AS INTEGER) \
                 ELSE NULL END AS duration_sec, \
            tq.finished_at \
        FROM translation_queue tq \
        LEFT JOIN audiobooks a ON a.id = tq.audiobook_id \
        WHERE ${where} \
        ORDER BY tq.finished_at ASC, a.title ASC;" 2>/dev/null)

    if [[ "$fmt" == "csv" ]]; then
        echo "title,author,locale,chapters,duration_sec,finished_at"
        # sqlite3 pipe-separated → CSV (quote fields containing commas/quotes)
        [[ -z "$rows" ]] && return 0
        while IFS='|' read -r title author locale chapters dur finished; do
            local q_title q_author
            q_title=$(printf '"%s"' "${title//\"/\"\"}")
            q_author=$(printf '"%s"' "${author//\"/\"\"}")
            printf '%s,%s,%s,%s,%s,%s\n' "$q_title" "$q_author" "$locale" "$chapters" "${dur:-}" "$finished"
        done <<<"$rows"
        return 0
    fi

    # Human-readable output
    echo -e "${BLUE}Completed Translations Report${NC}  $(date '+%Y-%m-%d %H:%M:%S')"
    [[ -n "$locale_filter" ]] && echo "  Locale filter: $locale_filter"
    [[ -n "$since_filter" ]] && echo "  Since:         $since_filter"
    echo "─────────────────────────────────────────────────────────────────────────────"

    if [[ -z "$rows" ]]; then
        echo "  (no completed translations match the filter)"
        return 0
    fi

    printf "  %-7s %-9s %-9s %s\n" "LOCALE" "CHAPTERS" "DURATION" "TITLE — AUTHOR"
    local total_books=0 total_chapters=0 total_duration=0
    while IFS='|' read -r title author locale chapters dur finished; do
        total_books=$((total_books + 1))
        total_chapters=$((total_chapters + ${chapters:-0}))
        local dur_label="—"
        if [[ -n "$dur" && "$dur" -gt 0 ]]; then
            total_duration=$((total_duration + dur))
            if [[ "$dur" -ge 3600 ]]; then
                dur_label="$((dur / 3600))h$(((dur % 3600) / 60))m"
            else
                dur_label="$((dur / 60))m$((dur % 60))s"
            fi
        fi
        local byline="${title}"
        [[ "$author" != "—" ]] && byline="${title} — ${author}"
        printf "  %-7s %-9s %-9s %s\n" "$locale" "${chapters:-0}" "$dur_label" "$byline"
    done <<<"$rows"

    if [[ "$show_summary" == "1" ]]; then
        local total_dur_label="—"
        if [[ "$total_duration" -gt 0 ]]; then
            total_dur_label="$((total_duration / 3600))h$(((total_duration % 3600) / 60))m"
        fi
        echo "─────────────────────────────────────────────────────────────────────────────"
        echo -e "${GREEN}Total:${NC} ${total_books} book-locale pair(s), ${total_chapters} chapter(s), ${total_dur_label} wall-clock"
    fi
}

# ── Dispatch ────────────────────────────────────────────────────────────────
case "${1:-}" in
    status)
        shift
        watch_mode=0
        watch_interval=5
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -w | --watch)
                    watch_mode=1
                    if [[ -n "${2:-}" && "$2" =~ ^[0-9]+$ ]]; then
                        watch_interval="$2"
                        shift
                    fi
                    ;;
                -w=* | --watch=*)
                    watch_mode=1
                    watch_interval="${1#*=}"
                    ;;
                *)
                    echo -e "${RED}Unknown option for status: $1${NC}" >&2
                    echo "Usage: audiobook-translations status [--watch [SECONDS]]"
                    exit 1
                    ;;
            esac
            shift
        done
        if [[ "$watch_mode" == "1" ]]; then
            cmd_status_watch "$watch_interval"
        else
            cmd_status
        fi
        ;;
    pause)
        cmd_pause
        ;;
    resume)
        cmd_resume
        ;;
    report)
        shift
        cmd_report "$@"
        ;;
    export | import)
        # Delegate to the Python transfer module
        cd "${AUDIOBOOKS_HOME}/library" || exit 1
        exec "$(audiobooks_python)" -m localization.transfer "$@"
        ;;
    -h | --help | help | "")
        usage
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        usage
        exit 1
        ;;
esac
