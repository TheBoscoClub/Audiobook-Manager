#!/bin/bash
# =============================================================================
# Disable Vox Grotto Conversion Auto-start
# =============================================================================

YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Disabling Vox Grotto conversion auto-start...${NC}"
echo ""

# Disable services
systemctl disable grotto-converter.service
systemctl disable grotto-mover.service

echo ""
echo "✓ Auto-start disabled"
echo ""
echo "Services will NOT start automatically on boot."
echo "You can still start manually with: grotto-start"
