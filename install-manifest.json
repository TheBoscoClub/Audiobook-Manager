{
  "name": "audiobooks",
  "version": "8.3.2",
  "description": "Self-hosted audiobook library browser with conversion, web player, and optional Audible downloading",
  "install_type": "system",
  "install_dir": "/opt/audiobooks",
  "service_user": "audiobooks",
  "service_group": "audiobooks",

  "github": {
    "repo": "TheBoscoClub/Audiobook-Manager",
    "api": "https://api.github.com/repos/TheBoscoClub/Audiobook-Manager",
    "releases": "https://github.com/TheBoscoClub/Audiobook-Manager/releases"
  },

  "management_scripts": [
    {
      "name": "upgrade.sh",
      "install_path": "/opt/audiobooks/scripts/upgrade.sh",
      "wrapper": "audiobook-upgrade",
      "description": "Upgrade from GitHub releases or local project"
    },
    {
      "name": "uninstall.sh",
      "install_path": "/opt/audiobooks/uninstall.sh",
      "description": "Comprehensive uninstall with dynamic discovery (also invoked by install.sh --uninstall)"
    },
    {
      "name": "migrate-api.sh",
      "install_path": "/opt/audiobooks/scripts/migrate-api.sh",
      "wrapper": "audiobook-migrate",
      "description": "Switch between API architectures"
    }
  ],

  "binaries": [
    {
      "name": "audiobook-api",
      "paths": ["/usr/local/bin/audiobook-api"],
      "description": "Start the API server"
    },
    {
      "name": "audiobook-web",
      "paths": ["/usr/local/bin/audiobook-web"],
      "description": "Start the web interface"
    },
    {
      "name": "audiobook-scan",
      "paths": ["/usr/local/bin/audiobook-scan"],
      "description": "Scan library for new audiobooks"
    },
    {
      "name": "audiobook-import",
      "paths": ["/usr/local/bin/audiobook-import"],
      "description": "Import audiobooks from sources"
    },
    {
      "name": "audiobook-config",
      "paths": ["/usr/local/bin/audiobook-config"],
      "description": "Manage configuration"
    },
    {
      "name": "audiobook-convert",
      "paths": ["/usr/local/bin/audiobook-convert"],
      "description": "Convert AAXC to Opus (alias: convert-audiobooks-opus-parallel)"
    },
    {
      "name": "audiobook-download",
      "paths": ["/usr/local/bin/audiobook-download"],
      "description": "Download from Audible (alias: download-new-audiobooks)"
    },
    {
      "name": "audiobook-move-staged",
      "paths": ["/usr/local/bin/audiobook-move-staged"],
      "description": "Move staged files to permanent storage (alias: move-staged-audiobooks)"
    },
    {
      "name": "audiobook-save-staging",
      "paths": ["/usr/local/bin/audiobook-save-staging"],
      "description": "Save staging area before shutdown"
    },
    {
      "name": "audiobook-save-staging-auto",
      "paths": ["/usr/local/bin/audiobook-save-staging-auto"],
      "description": "Automatic staging save (called by shutdown service)"
    },
    {
      "name": "audiobook-upgrade",
      "paths": ["/usr/local/bin/audiobook-upgrade"],
      "description": "Upgrade from GitHub releases"
    },
    {
      "name": "audiobook-migrate",
      "paths": ["/usr/local/bin/audiobook-migrate"],
      "description": "Switch API architecture"
    },
    {
      "name": "audiobook-status",
      "paths": ["/usr/local/bin/audiobook-status"],
      "description": "Show service and timer status"
    },
    {
      "name": "audiobook-start",
      "paths": ["/usr/local/bin/audiobook-start"],
      "description": "Start all audiobook services"
    },
    {
      "name": "audiobook-stop",
      "paths": ["/usr/local/bin/audiobook-stop"],
      "description": "Stop all audiobook services"
    },
    {
      "name": "audiobook-enable",
      "paths": ["/usr/local/bin/audiobook-enable"],
      "description": "Enable services for auto-start at boot"
    },
    {
      "name": "audiobook-disable",
      "paths": ["/usr/local/bin/audiobook-disable"],
      "description": "Disable services from auto-start at boot"
    },
    {
      "name": "audiobook-help",
      "paths": ["/usr/local/bin/audiobook-help"],
      "description": "Display help and usage information"
    },
    {
      "name": "audiobook-user",
      "paths": ["/usr/local/bin/audiobook-user"],
      "description": "Admin CLI for user management"
    },
    {
      "name": "audiobook-download-monitor",
      "paths": ["/usr/local/bin/audiobook-download-monitor"],
      "description": "Monitor Audible download progress"
    },
    {
      "name": "audiobook-monitor",
      "paths": ["/usr/local/bin/audiobook-monitor"],
      "description": "Live conversion monitor (alias: monitor-audiobook-conversion)"
    },
    {
      "name": "audiobook-build-queue",
      "paths": ["/usr/local/bin/audiobook-build-queue"],
      "description": "Build conversion queue (alias: build-conversion-queue)"
    },
    {
      "name": "audiobook-copy-metadata",
      "paths": ["/usr/local/bin/audiobook-copy-metadata"],
      "description": "Copy metadata between audiobooks (alias: copy-audiobook-metadata)"
    },
    {
      "name": "audiobook-cleanup-indexes",
      "paths": ["/usr/local/bin/audiobook-cleanup-indexes"],
      "description": "Remove stale database indexes (alias: cleanup-stale-indexes)"
    },
    {
      "name": "audiobook-find-duplicates",
      "paths": ["/usr/local/bin/audiobook-find-duplicates"],
      "description": "Find duplicate source files (alias: find-duplicate-sources)"
    },
    {
      "name": "audiobook-fix-chapters",
      "paths": ["/usr/local/bin/audiobook-fix-chapters"],
      "description": "Fix malformed chapters JSON (alias: fix-wrong-chapters-json)"
    },
    {
      "name": "audiobook-embed-covers",
      "paths": ["/usr/local/bin/audiobook-embed-covers"],
      "description": "Embed cover art into Opus files (alias: embed-cover-art.py)"
    },
    {
      "name": "audiobook-purge-cache",
      "paths": ["/usr/local/bin/audiobook-purge-cache"],
      "description": "Purge cover art and metadata cache"
    }
  ],

  "services": [
    {
      "name": "audiobook-api.service",
      "type": "system",
      "expected_state": "active",
      "description": "API server (Gunicorn+geventwebsocket)",
      "health_endpoint": "http://localhost:${AUDIOBOOKS_API_PORT:-5001}/health"
    },
    {
      "name": "audiobook-proxy.service",
      "type": "system",
      "expected_state": "active",
      "description": "HTTPS reverse proxy for web interface"
    },
    {
      "name": "audiobook-redirect.service",
      "type": "system",
      "expected_state": "active",
      "description": "HTTP to HTTPS redirect"
    },
    {
      "name": "audiobook-converter.service",
      "type": "system",
      "expected_state": "active",
      "description": "Continuous AAXC to Opus converter"
    },
    {
      "name": "audiobook-downloader.service",
      "type": "system",
      "expected_state": "inactive",
      "description": "Audible sync (triggered by timer)"
    },
    {
      "name": "audiobook-downloader.timer",
      "type": "system",
      "expected_state": "active",
      "description": "Timer for Audible sync"
    },
    {
      "name": "audiobook-mover.service",
      "type": "system",
      "expected_state": "active",
      "description": "Staging mover daemon"
    },
    {
      "name": "audiobook-shutdown-saver.service",
      "type": "system",
      "expected_state": "inactive",
      "description": "Shutdown hook to save staging"
    },
    {
      "name": "audiobook-upgrade-helper.path",
      "type": "system",
      "expected_state": "active",
      "description": "Watches for upgrade triggers"
    },
    {
      "name": "audiobook-upgrade-helper.service",
      "type": "system",
      "expected_state": "inactive",
      "description": "Runs upgrade when triggered by path unit (oneshot, normally inactive)"
    },
    {
      "name": "audiobook-scheduler.service",
      "type": "system",
      "expected_state": "active",
      "description": "Maintenance task scheduler daemon"
    },
    {
      "name": "audiobook.target",
      "type": "system",
      "expected_state": "active",
      "description": "Target grouping all audiobook services"
    }
  ],

  "config_files": [
    {
      "path": "/etc/audiobooks/audiobooks.conf",
      "required": true,
      "description": "Main configuration file"
    },
    {
      "path": "/var/lib/audiobooks/db/audiobooks.db",
      "required": true,
      "description": "SQLite database (canonical, in db/ subdirectory)"
    },
    {
      "path": "/etc/logrotate.d/audiobooks",
      "required": false,
      "description": "Log rotation configuration"
    }
  ],

  "data_directories": [
    {
      "path": "/var/lib/audiobooks",
      "required": true,
      "min_permissions": "755",
      "description": "Persistent state directory (BTRFS subvolume on NVMe)",
      "btrfs_subvolume": true
    },
    {
      "path": "/etc/audiobooks",
      "required": true,
      "min_permissions": "755",
      "description": "System configuration directory (BTRFS subvolume on NVMe)",
      "btrfs_subvolume": true
    },
    {
      "path": "/opt/audiobooks",
      "required": true,
      "min_permissions": "755",
      "description": "Application installation directory"
    },
    {
      "path": "/opt/audiobooks/library",
      "required": true,
      "min_permissions": "755",
      "description": "Library code"
    },
    {
      "path": "/opt/audiobooks/scripts",
      "required": true,
      "min_permissions": "755",
      "description": "Management scripts (upgrade, migrate)"
    },
    {
      "path": "${AUDIOBOOKS_DATA}",
      "required": true,
      "min_permissions": "755",
      "description": "Audiobook data root (configurable via AUDIOBOOKS_DATA)"
    },
    {
      "path": "${AUDIOBOOKS_LIBRARY}",
      "required": true,
      "min_permissions": "755",
      "description": "Converted audiobooks (Opus)"
    },
    {
      "path": "${AUDIOBOOKS_SOURCES}",
      "required": true,
      "min_permissions": "755",
      "description": "Source audiobooks (AAXC)"
    },
    {
      "path": "${AUDIOBOOKS_DATA}/.covers",
      "required": false,
      "min_permissions": "755",
      "description": "Cover art cache (created as needed)"
    }
  ],

  "environment": {
    "required_vars": [
      "AUDIOBOOKS_DATA",
      "AUDIOBOOKS_LIBRARY",
      "AUDIOBOOKS_DATABASE"
    ],
    "optional_vars": [
      "AUDIOBOOKS_API_PORT",
      "AUDIOBOOKS_WEB_PORT",
      "AUDIOBOOKS_HTTPS_ENABLED",
      "AUDIOBOOKS_DEV_MODE",
      "AUDIOBOOKS_COVERS"
    ]
  },

  "ports": [
    {
      "port": 5001,
      "protocol": "tcp",
      "service": "audiobook-api.service",
      "description": "REST API (default, configurable via AUDIOBOOKS_API_PORT)",
      "env_override": "AUDIOBOOKS_API_PORT"
    },
    {
      "port": 8443,
      "protocol": "tcp",
      "service": "audiobook-proxy.service",
      "description": "HTTPS web interface (default, configurable via AUDIOBOOKS_WEB_PORT)",
      "env_override": "AUDIOBOOKS_WEB_PORT"
    },
    {
      "port": 8080,
      "protocol": "tcp",
      "service": "audiobook-redirect.service",
      "description": "HTTP redirect (default, configurable via AUDIOBOOKS_HTTP_REDIRECT_PORT)",
      "env_override": "AUDIOBOOKS_HTTP_REDIRECT_PORT"
    }
  ],

  "health_checks": [
    {
      "name": "API health endpoint",
      "command": "curl -sf http://localhost:${AUDIOBOOKS_API_PORT:-5001}/health",
      "timeout": 10
    },
    {
      "name": "Web interface accessible",
      "command": "curl -sfk https://localhost:${AUDIOBOOKS_WEB_PORT:-8443}/ -o /dev/null",
      "timeout": 10
    },
    {
      "name": "Database accessible",
      "command": "test -f /var/lib/audiobooks/db/audiobooks.db && sqlite3 /var/lib/audiobooks/db/audiobooks.db 'SELECT 1'",
      "timeout": 5
    },
    {
      "name": "Library directory readable",
      "command": "test -d \"${AUDIOBOOKS_LIBRARY}\" && ls \"${AUDIOBOOKS_LIBRARY}\" >/dev/null",
      "timeout": 5
    }
  ]
}
