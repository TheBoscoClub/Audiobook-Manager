#!/bin/bash
# commit-msg hook: Strip AI/vendor promotional content from commit messages.
# Silently removes Co-Authored-By trailers referencing AI tools, vendor
# email addresses, and "Generated with" attribution lines.
#
# This runs on EVERY commit, modifying the message in-place before it's
# recorded. No user interaction needed — promotional lines are deleted
# and the commit proceeds with the cleaned message.

COMMIT_MSG_FILE="$1"

# Patterns to remove (case-insensitive, full-line deletion)
sed -i -E '/Co-Authored-By:.*Claude/Id' "$COMMIT_MSG_FILE"
sed -i -E '/Co-Authored-By:.*Anthropic/Id' "$COMMIT_MSG_FILE"
sed -i -E '/Co-Authored-By:.*noreply@/Id' "$COMMIT_MSG_FILE"
sed -i -E '/Co-Authored-By:.*(Copilot|GPT|OpenAI|Gemini|Cursor)/Id' "$COMMIT_MSG_FILE"
sed -i -E '/noreply@anthropic\.com/Id' "$COMMIT_MSG_FILE"
sed -i -E '/Generated with \[?Claude/Id' "$COMMIT_MSG_FILE"
sed -i -E '/Generated with \[?Claude Code\]?/Id' "$COMMIT_MSG_FILE"

# Remove trailing blank lines left behind
sed -i -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$COMMIT_MSG_FILE"

exit 0
