[codespell]
skip = .git,.venv,venv,node_modules,.snapshots,*.db,*.pyc,__pycache__,converter,library/scripts/nohup.out,htmlcov,coverage_html,*.html,library/locales,library/web-v2/js/library.js
ignore-words-list = brach,nd,ser,te,couldn,optionel,wee,wil,walkin,worl,kno,reacher,achievin,caf,fo,playfull,autor,astroid,prevEnd
