# Audiobook Library Configuration
# ================================
# Copy this file to one of these locations:
#   System-wide: /etc/audiobooks/audiobooks.conf
#   User-only:   ~/.config/audiobooks/audiobooks.conf
#
# Environment variables override these settings.
# Values are read in this order (later overrides earlier):
#   1. Built-in defaults
#   2. /etc/audiobooks/audiobooks.conf (system)
#   3. ~/.config/audiobooks/audiobooks.conf (user)
#   4. Environment variables
#   5. Command-line arguments

# =============================================================================
# Core Directories
# =============================================================================

# Root directory containing all audiobook data (sources, library, supplements)
# Default: /srv/audiobooks (system) or ~/Audiobooks (user)
AUDIOBOOKS_DATA="/srv/audiobooks"

# Converted audiobook files organized by Author/Title
# Default: ${AUDIOBOOKS_DATA}/Library
AUDIOBOOKS_LIBRARY="${AUDIOBOOKS_DATA}/Library"

# Original source files (AAXC, vouchers, metadata)
# Default: ${AUDIOBOOKS_DATA}/Sources
AUDIOBOOKS_SOURCES="${AUDIOBOOKS_DATA}/Sources"

# PDF supplements and companion materials
# Default: ${AUDIOBOOKS_DATA}/Supplements
AUDIOBOOKS_SUPPLEMENTS="${AUDIOBOOKS_DATA}/Supplements"

# =============================================================================
# Application Directories
# =============================================================================

# Project installation directory (contains scripts, web UI, etc.)
# Default: /opt/audiobooks (system) or detected from script location
AUDIOBOOKS_HOME="/opt/audiobooks"

# Database file location
# Default: /var/lib/audiobooks/db/audiobooks.db (system)
#      or: ${AUDIOBOOKS_HOME}/library/backend/audiobooks.db (user)
AUDIOBOOKS_DATABASE="/var/lib/audiobooks/db/audiobooks.db"

# Cover art cache directory
# Default: /var/lib/audiobooks/covers
AUDIOBOOKS_COVERS="/var/lib/audiobooks/covers"

# SSL certificate directory (for HTTPS)
# Default: ${AUDIOBOOKS_HOME}/library/certs
AUDIOBOOKS_CERTS="${AUDIOBOOKS_HOME}/library/certs"

# WebM cache directory (for browser-compatible audio streams)
# Default: ${AUDIOBOOKS_DATA}/.webm-cache
#AUDIOBOOKS_WEBM_CACHE="${AUDIOBOOKS_DATA}/.webm-cache"

# Log file directory
# Default: ${AUDIOBOOKS_DATA}/logs
AUDIOBOOKS_LOGS="${AUDIOBOOKS_DATA}/logs"

# =============================================================================
# Server Configuration
# =============================================================================

# API server port
# Default: 5001
AUDIOBOOKS_API_PORT="5001"

# Web server port (HTTPS) - changed from 8090 to 8443
# Default: 8443
AUDIOBOOKS_WEB_PORT="8443"

# Bind address (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
# Default: 0.0.0.0
AUDIOBOOKS_BIND_ADDRESS="0.0.0.0"

# HTTP to HTTPS redirect port
# Default: 8080
AUDIOBOOKS_HTTP_REDIRECT_PORT="8080"

# Use waitress WSGI server (production mode)
# Default: true
AUDIOBOOKS_USE_WAITRESS="true"

# =============================================================================
# Optional Features
# =============================================================================

# Enable HTTPS for web server (requires certificate)
# Default: true
AUDIOBOOKS_HTTPS_ENABLED="true"

# Python virtual environment path (for API server)
# Default: ${AUDIOBOOKS_HOME}/library/venv
AUDIOBOOKS_VENV="${AUDIOBOOKS_HOME}/library/venv"

# AAXtoMP3 converter location
# Default: ${AUDIOBOOKS_HOME}/converter/AAXtoMP3
AUDIOBOOKS_CONVERTER="${AUDIOBOOKS_HOME}/converter/AAXtoMP3"

# =============================================================================
# Authentication (Multi-user Support)
# =============================================================================

# Enable authentication for remote access
# When enabled, users must log in to access the library
# When disabled (default), admin endpoints are restricted to localhost
# Default: false (standalone mode, no auth required)
AUTH_ENABLED="false"

# Authentication database path (SQLCipher encrypted)
# Default: /var/lib/audiobooks/auth.db
AUTH_DATABASE="/var/lib/audiobooks/auth.db"

# Encryption key file for auth database
# IMPORTANT: This file must be readable only by the audiobooks user (chmod 600)
# Default: /etc/audiobooks/auth.key
AUTH_KEY_FILE="/etc/audiobooks/auth.key"

# Development mode for auth (relaxed key permissions, verbose logging)
# Default: false
AUDIOBOOKS_DEV_MODE="false"

# =============================================================================
# Remote Access (only needed when AUTH_ENABLED="true")
# =============================================================================
# These settings are for exposing the library over the internet.
# You can use any reverse proxy (Caddy, nginx, Traefik) and any DNS/tunnel
# provider (Cloudflare, DuckDNS, Tailscale, WireGuard, etc.)

# Your public domain or hostname (used for WebAuthn and email links)
# Examples: library.example.com, audiobooks.myserver.net
# Default: auto-detected from request (works for localhost without config)
#AUDIOBOOKS_HOSTNAME=""

# Base URL for email links (magic links, invitations)
# Example: https://library.example.com
# Default: auto-detected from request
#BASE_URL=""

# CORS allowed origin (restricts which domains can make API requests)
# Set this to your public URL for security when exposed to the internet
# Example: https://library.example.com
# Default: * (permissive, safe for standalone/localhost)
#CORS_ORIGIN=""

# WebAuthn/Passkey configuration (auto-derived from AUDIOBOOKS_HOSTNAME)
# Only set these if you need to override the auto-detection
#WEBAUTHN_RP_ID=""          # Relying Party ID (usually your domain)
#WEBAUTHN_RP_NAME=""        # Display name (default: "The Library")
#WEBAUTHN_ORIGIN=""         # Expected origin (default: https://{AUDIOBOOKS_HOSTNAME})

# =============================================================================
# Email / SMTP (only needed for invitation and recovery emails)
# =============================================================================

# SMTP server for sending emails (magic links, invitations, notifications)
# Leave unconfigured if you don't need email — admin can share claim tokens manually
#SMTP_HOST="smtp.example.com"
#SMTP_PORT="587"
#SMTP_USER=""
#SMTP_PASS=""
#SMTP_FROM="library@example.com"
#ADMIN_EMAIL=""

# =============================================================================
# Performance & Advanced Settings
# =============================================================================

# Number of parallel conversion jobs
# Default: number of CPU cores
AUDIOBOOKS_PARALLEL_JOBS="8"

# Data directory for scan results and intermediate files
# Default: /var/lib/audiobooks/data
DATA_DIR="/var/lib/audiobooks/data"

# Index directory for checksum files (duplicates detection)
# NOTE: Currently unused — reserved for future implementation
#AUDIOBOOKS_INDEX="/var/lib/audiobooks/db/.index"
