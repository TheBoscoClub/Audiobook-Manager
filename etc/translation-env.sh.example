#!/bin/bash
# translation-env.sh — Site-local translation pipeline configuration
#
# Copy this file to /etc/audiobooks/scripts/translation-env.sh and customize
# for your GPU infrastructure. The translation daemon sources this file to
# discover available GPU workers and configure the pipeline.
#
# After editing, restart the translation daemon:
#   systemctl restart audiobook-translate
#
# ===========================================================================
# IMPORTANT: This file contains YOUR infrastructure details (SSH keys, cloud
# instance IDs, API keys). It lives in /etc/audiobooks/scripts/ which is
# never overwritten by upgrade.sh — your config survives upgrades.
# ===========================================================================

# ── Paths ───────────────────────────────────────────────────────────────────
# These default to the standard install locations. Override if your setup
# differs (e.g., custom data directory, non-standard venv location).

# DB_PATH="/var/lib/audiobooks/db/audiobooks.db"
# LIBRARY_PATH="/srv/audiobooks/Library"
# VENV_PYTHON="/opt/audiobooks/library/venv/bin/python"
# LOG_DIR="/var/log/audiobooks/translate"
# PID_FILE="/var/lib/audiobooks/.run/translate-daemon.pid"

# ── Daemon Behavior ─────────────────────────────────────────────────────────

# Seconds between tunnel/worker health checks
# HEALTH_CHECK_INTERVAL=120

# Consecutive empty queue checks before auto-stop (prevents premature exit
# if workers are slow to report completion)
# EMPTY_QUEUE_CHECKS=3

# Parallel books processed per GPU. Default 4 is safe for L40S (48GB) with
# Whisper large-v3 float16 — a single model instance serves N gunicorn
# gthread requests concurrently (CUDA releases the GIL). Smaller GPUs
# (RTX 4090 24GB, A4000 16GB) should use 2; A100 80GB can push to 6–8.
# Set to 1 to restore the pre-v8.2.3.5 single-stream behavior.
# WORKERS_PER_GPU=4

# ── Vast.ai GPU Instances ──────────────────────────────────────────────────
# Format: "local_port|ssh_port|ssh_host|label|compute_type"
#
# The daemon creates SSH tunnels to each instance and starts Whisper servers.
# local_port: Port on localhost where the tunnel endpoint appears
# ssh_port:   SSH port assigned by Vast.ai (from instance details)
# ssh_host:   SSH hostname (e.g., ssh5.vast.ai)
# label:      Human-readable name for logs
# compute_type: Whisper compute type (float16 for GPU, auto for fallback)
#
# SSH key for tunnels:
# SSH_KEY="/home/YOUR_USER/.ssh/id_ed25519"
#
# Example (uncomment and customize):
# VASTAI_INSTANCES=(
#     "8100|12345|ssh5.vast.ai|rtx4090-us|float16"
#     "8101|12346|ssh8.vast.ai|a100-eu|float16"
# )

VASTAI_INSTANCES=()

# ── RunPod GPU Instances ───────────────────────────────────────────────────
# Format: "https_proxy_url|label"
#
# RunPod pods use HTTPS proxy URLs instead of SSH tunnels. Get the proxy URL
# from your RunPod dashboard: Pod Details > Connect > HTTP Service Port 8000.
#
# Example (uncomment and customize):
# RUNPOD_INSTANCES=(
#     "https://abc123def456-8000.proxy.runpod.net|runpod-a100-1"
#     "https://xyz789ghi012-8000.proxy.runpod.net|runpod-a4000-1"
# )

RUNPOD_INSTANCES=()

# ── GPU Teardown ────────────────────────────────────────────────────────────
# When the translation queue empties, the daemon can automatically destroy
# cloud GPU instances to stop billing. API keys are read from the file below.
#
# Set to "true" to enable auto-teardown on queue empty.
# AUTO_TEARDOWN_GPU=true
#
# File containing VAST_API_KEY and/or RUNPOD_API_KEY (one per line, KEY=value)
# GPU_API_KEYS_FILE="${HOME}/.config/api-keys.env"

AUTO_TEARDOWN_GPU=false
# GPU_API_KEYS_FILE=""

# ── Email Notification ──────────────────────────────────────────────────────
# Send a verification report when the translation queue is fully processed.
# SMTP settings are read from /etc/audiobooks/audiobooks.conf (SMTP_HOST,
# SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM).
#
# Set the recipient email to enable notifications:
# NOTIFY_EMAIL="you@example.com"

NOTIFY_EMAIL=""

# ── Self-Hosted Whisper ─────────────────────────────────────────────────────
# If you run your own Whisper server (not cloud GPU), specify the endpoint.
# The daemon will use this instead of Vast.ai/RunPod instances.
#
# LOCAL_WHISPER_URL="http://192.168.1.50:8000"

# ── Custom Post-Completion Hook ─────────────────────────────────────────────
# Path to a script that runs after the queue empties and verification passes.
# Use this for custom teardown, notifications, or data processing.
#
# POST_COMPLETION_HOOK="/etc/audiobooks/scripts/my-post-translate.sh"
